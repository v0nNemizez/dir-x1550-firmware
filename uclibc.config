# uClibc 0.9.33.2 konfigurasjon for MIPS32 Big Endian
# Tilpasset for Realtek RTL8198D

# Arkitektur
TARGET_mips=y
TARGET_ARCH="mips"
TARGET_ABI="o32"

# Endianness – Big Endian
ARCH_BIG_ENDIAN=y
ARCH_WANTS_BIG_ENDIAN=y
# ARCH_LITTLE_ENDIAN is not set
# ARCH_WANTS_LITTLE_ENDIAN is not set

# MIPS-spesifikt
CONFIG_MIPS_ISA_1=n
CONFIG_MIPS_ISA_MIPS32=n
CONFIG_MIPS_ISA_MIPS32R2=y
CONFIG_MIPS_ISA_MIPS64=n
ARCH_MIPS_HARD_FLOAT=y
# ARCH_MIPS_SOFT_FLOAT is not set

# Generelle innstillinger
HAVE_DOT_CONFIG=y
DEVEL_PREFIX="/usr"
RUNTIME_PREFIX="/"
KERNEL_HEADERS="/home/builder/.build/mips-linux-uclibc/linux-4.4.302/include"
UCLIBC_EXTRA_CFLAGS=""

# Tråding
PTHREADS_DEBUG_SUPPORT=n
UCLIBC_HAS_THREADS=y
UCLIBC_HAS_THREADS_NATIVE=y
LINUXTHREADS_OLD=n
LINUXTHREADS_NEW=n
UCLIBC_HAS_LINUXTHREADS=n

# Funksjonalitet
UCLIBC_HAS_LOCALE=n
UCLIBC_HAS_WCHAR=y
UCLIBC_HAS_GLIBC_CUSTOM_PRINTF=y
UCLIBC_HAS_FOPEN_EXCLUSIVE_MODE=y
UCLIBC_HAS_FOPEN_CLOSEEXEC_MODE=y
UCLIBC_HAS_STDIO_BUFSIZ_256=n
UCLIBC_HAS_STDIO_BUFSIZ_512=n
UCLIBC_HAS_STDIO_BUFSIZ_1024=n
UCLIBC_HAS_STDIO_BUFSIZ_2048=n
UCLIBC_HAS_STDIO_BUFSIZ_4096=y
UCLIBC_HAS_STDIO_BUFSIZ_8192=n
UCLIBC_HAS_STDIO_GETC_MACRO=y
UCLIBC_HAS_STDIO_PUTC_MACRO=y
UCLIBC_HAS_STDIO_AUTO_RW_TRANSITION=y
UCLIBC_HAS_FLOATS=y
UCLIBC_HAS_FPU=y
UCLIBC_HAS_SOFT_FLOAT=n
HAS_FPU=y
UCLIBC_HAS_LONG_DOUBLE_MATH=n
DO_C99_MATH=y
UCLIBC_HAS_FENV=y
UCLIBC_HAS_REALTIME=y
UCLIBC_HAS_ADVANCED_REALTIME=y
UCLIBC_HAS_EPOLL=y
UCLIBC_HAS_XATTR=y
UCLIBC_HAS_POSIX_FALLOCATE=y
UCLIBC_HAS_LFS=y
MALLOC=y
MALLOC_SIMPLE=n
MALLOC_STANDARD=y
MALLOC_GLIBC_COMPAT=y
UCLIBC_DYNAMIC_ATEXIT=y
UCLIBC_SUSV3_LEGACY=y
UCLIBC_SUSV3_LEGACY_MACROS=y
UCLIBC_HAS_BSD_ERR=y
UCLIBC_HAS_SYSLOG=y
UCLIBC_HAS_SHADOW=y
UCLIBC_HAS_REGEX=y
UCLIBC_HAS_REGEX_OLD=n
UCLIBC_HAS_FNMATCH=y
UCLIBC_HAS_FNMATCH_OLD=n
UCLIBC_HAS_WORDEXP=y
UCLIBC_HAS_GLOB=y
UCLIBC_HAS_GNU_GETOPT=y
UCLIBC_HAS_GETTEXT_AWARENESS=y
UCLIBC_HAS_ARGP=y
UCLIBC_HAS_UTMPX=y
UCLIBC_HAS_UTMP=y
UCLIBC_HAS_IPV6=y
UCLIBC_HAS_RPC=y
UCLIBC_HAS_FULL_RPC=y
UCLIBC_HAS_REENTRANT_RPC=y
UCLIBC_USE_NETLINK=y
UCLIBC_SUPPORT_AI_ADDRCONFIG=y
UCLIBC_HAS_COMPAT_RES_STATE=y
UCLIBC_HAS_LIBNSL=y

# Stripping og optimalisering
UCLIBC_STRIPPED_HEADERS=n
LDSO_SAFE_RUNPATH=y
LDSO_SEARCH_INTERP_SPEC=n
LDSO_GNU_HASH_SUPPORT=y

# Versjon
UCLIBC_HAS_SSP=y
UCLIBC_HAS_SSP_COMPAT=y
PREGEN_LOCALE=n
